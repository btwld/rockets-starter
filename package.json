    "type-check": "turbo type-check",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@turbo/gen": "^1.10.7",
    "turbo": "^1.10.7"
  },
  "packageManager": "yarn@1.22.19",
  "resolutions": {
    "@nestjs/common": "11.1.11",
    "@nestjs/core": "11.1.11",
    "@bitwild/rockets/@nestjs/common": "11.1.11",
    "@bitwild/rockets/@nestjs/core": "11.1.11",
    "@bitwild/rockets-auth/@nestjs/common": "11.1.11",
    "@bitwild/rockets-auth/@nestjs/core": "11.1.11",
    "@concepta/nestjs-common": "7.0.0-alpha.10",
    "@concepta/nestjs-jwt": "7.0.0-alpha.10",
    "@concepta/nestjs-authentication": "7.0.0-alpha.10",
    "@concepta/nestjs-event": "7.0.0-alpha.10",
