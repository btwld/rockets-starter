# Node Environment
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rockets-starter
DATABASE_SSL=false

# Email Configuration
EMAIL_FROM=noreply@rockets-starter.com
EMAIL_LOGO_URL=https://example.com/logo.png

# Application Configuration
APP_BASE_URL=http://localhost:3001

# OTP Configuration
OTP_EXPIRES_IN=10m

# Role Configuration
ADMIN_ROLE_NAME=admin
DEFAULT_ROLE_NAME=user

# Rockets Module Configuration
ENABLE_GLOBAL_GUARD=true

# Database Migrations and Seeding
# Run migrations: yarn migration:run
# Generate migration: yarn migration:generate ./src/migrations/MigrationName
# Revert migration: yarn migration:revert
# Seed database: yarn seed:run
# Initialize database: yarn sandbox:init (runs migrations + seeding)
